# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings → API).
#
# Both values are *publishable* — the anon key is safe to ship in client code,
# because Row Level Security policies in supabase/schema.sql restrict every
# query to rows owned by the authenticated user.
#
# DO NOT put the service_role key here. It bypasses RLS and must stay server-side.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
